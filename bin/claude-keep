#!/usr/bin/env bash
# claude-keep — claude-session-keeper: persist long-running Claude Code (Remote Control)
# tmux sessions across reboots and crashes, and self-heal them on a timer.
#
# A session registers ITSELF (no args — reads its own env), the registry is a
# plain TSV, and `claude-keep restore` re-launches anything that died. A systemd --user
# timer runs `restore` periodically so a session that dies (reboot, OOM, the Mac
# sleeping and dropping a network-mounted cwd) comes back on its own.
#
# Subcommands:
#   claude-keep add [--no-rc] [--effort <e>]   Register THIS session (reads $CLAUDE_CODE_SESSION_ID,
#                                      the tmux session name, $PWD, $CLAUDE_EFFORT).
#   claude-keep rm [name]                      Remove THIS session (no arg) or a named one.
#   claude-keep ls                             List the registry + who is live right now.
#   claude-keep restore                        Re-launch every registered session that isn't live.
#   claude-keep rc-restore [--now]             Re-establish Remote Control on LIVE sessions whose RC
#                                      dropped; alert (via $KEEP_NOTIFY_CMD) when a manual re-login is
#                                      what's blocking it. --now skips the hysteresis (on-demand).
#   claude-keep install-timer [--interval M]   Install a systemd --user timer (default 5 min) → restore.
#   claude-keep uninstall-timer                Remove the restore timer.
#   claude-keep install-rc-timer [--interval M]  Install a systemd --user timer → rc-restore (RC monitor).
#   claude-keep uninstall-rc-timer             Remove the RC monitor timer.
#
# Registry: ${CLAUDE_KEEP_HOME:-~/.claude-keep}/sessions.tsv
#   columns: tmux_name <TAB> uuid <TAB> cwd <TAB> effort <TAB> rc
#   rc=1 → re-issue /remote-control after resume (these are Remote Control sessions);
#   rc=0 → plain tmux session, no Remote Control.
#
# Notes:
#   - model is NOT stored: `claude --resume <uuid>` restores the session's own model.
#   - restore answers the "Resume session?" dialog with option 2 (full) — never a
#     lossy summary — matching the long-running-session convention.
#   - a missing/unreachable cwd (e.g. a network mount not up yet) is SKIPPED, not
#     failed — the next timer tick retries once the mount is back. claude-keep knows nothing
#     about mounts; keep mounts healthy with their own keeper.

set -uo pipefail

CLAUDE_KEEP_HOME="${CLAUDE_KEEP_HOME:-$HOME/.claude-keep}"
TSV="$CLAUDE_KEEP_HOME/sessions.tsv"
# Resolve the claude binary to an absolute path: prefer PATH, then known install
# locations. The systemd --user timer runs with a minimal PATH that usually lacks
# ~/.npm-global/bin, so a bare `command -v claude` is not enough. Honour an explicit
# $CLAUDE override. (Mirrors resolve_claude() in claude-remote-launcher.)
_resolve_claude() {
  local c
  c=$(command -v claude 2>/dev/null) && { printf '%s\n' "$c"; return 0; }
  for c in "$HOME/.npm-global/bin/claude" "$HOME/.local/bin/claude" \
           "$HOME/.claude/local/claude" /usr/local/bin/claude; do
    [[ -x "$c" ]] && { printf '%s\n' "$c"; return 0; }
  done
  printf '%s\n' "$HOME/.npm-global/bin/claude"   # last-resort guess; -x is checked at use
}
CLAUDE="${CLAUDE:-$(_resolve_claude)}"
EM=$'—'   # em-dash used in cc— session names

# ── styled output ─────────────────────────────────────────
if [[ -t 1 ]]; then
  _g() { printf '\033[32m%s\033[0m' "$*"; }
  _y() { printf '\033[33m%s\033[0m' "$*"; }
  _r() { printf '\033[31m%s\033[0m' "$*"; }
  _b() { printf '\033[1m%s\033[0m' "$*"; }
else
  _g() { printf '%s' "$*"; }; _y() { printf '%s' "$*"; }
  _r() { printf '%s' "$*"; }; _b() { printf '%s' "$*"; }
fi
die() { _r "✗ $*" >&2; echo >&2; exit 1; }

# ── notifications (optional, pluggable) ───────────────────────────────────────
# The keeper never sends over the network itself and bundles no notifier. Point
# $KEEP_NOTIFY_CMD at ANY command that takes the message as its first argument — a
# Telegram bot wrapper, an ntfy one-liner (`curl -d "$1" ntfy.sh/your-topic`), your
# own script — to receive alerts. Unset → the keeper stays silent (logs to stderr).
# This keeps the repo notifier-agnostic; wire your channel in via the env var.
notify() {
  local cmd="${KEEP_NOTIFY_CMD:-}"
  if [[ -n "$cmd" ]]; then
    "$cmd" "$*" >/dev/null 2>&1 || printf 'claude-keep: notify failed: %s\n' "$*" >&2
  else
    printf 'claude-keep: [no notifier] %s\n' "$*" >&2
  fi
}

ensure_registry() {
  mkdir -p "$CLAUDE_KEEP_HOME"
  if [[ ! -f "$TSV" ]]; then
    {
      echo "# claude-session-keeper registry"
      echo "# tmux_name<TAB>uuid<TAB>cwd<TAB>effort<TAB>rc   (rc=1 → re-enable Remote Control)"
    } > "$TSV"
  fi
}

# ── identify the calling session from its own environment ──
self_tmux_name() { tmux display-message -p '#{session_name}' 2>/dev/null; }
self_uuid()      { printf '%s' "${CLAUDE_CODE_SESSION_ID:-}"; }
self_effort()    { printf '%s' "${CLAUDE_EFFORT:-}"; }

# exact field-1 (tmux_name) match — NOT a substring grep, which would let
# "neighbor/x" match inside "cc—neighbor/x".
_has_row() {
  awk -F'\t' -v n="$1" '$1==n {found=1} END{exit found?0:1}' "$TSV" 2>/dev/null
}
# remove any registry row whose tmux_name (field 1) equals $1; returns 0 iff it removed one
_drop_row() {
  _has_row "$1" || return 1
  local tmp; tmp=$(mktemp)
  awk -F'\t' -v n="$1" 'NF==0 || $1 ~ /^#/ || $1 != n' "$TSV" > "$tmp" && mv "$tmp" "$TSV"
}

# ──────────────────────────────────────────────────────────────────
cmd_add() {
  local no_rc=0 effort_override="" rc=1
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --no-rc) no_rc=1 ;;
      --effort) effort_override="${2:-}"; shift ;;
      *) die "add: unknown arg '$1'" ;;
    esac
    shift
  done

  local uuid name cwd effort
  uuid=$(self_uuid)
  name=$(self_tmux_name)
  cwd="$PWD"
  effort="${effort_override:-$(self_effort)}"
  (( no_rc )) && rc=0

  [[ -n "$uuid" ]] || die "no \$CLAUDE_CODE_SESSION_ID — run 'claude-keep add' from inside a Claude Code session"
  [[ -n "$name" ]] || die "not inside a tmux session (no \$TMUX) — claude-keep tracks tmux sessions"

  ensure_registry
  _drop_row "$name"                                   # upsert by tmux_name
  printf '%s\t%s\t%s\t%s\t%s\n' "$name" "$uuid" "$cwd" "$effort" "$rc" >> "$TSV"
  _g "✓ registered: $name"; echo
  echo "    uuid:   $uuid"
  echo "    cwd:    $cwd"
  echo "    effort: ${effort:-<default>}    remote-control: $([[ $rc == 1 ]] && echo yes || echo no)"
}

# ──────────────────────────────────────────────────────────────────
cmd_rm() {
  ensure_registry
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    name=$(self_tmux_name)
    [[ -n "$name" ]] || die "rm: no session name given and not inside a tmux session"
  elif ! _has_row "$name" && _has_row "cc${EM}${name}"; then
    name="cc${EM}${name}"          # accept the bare title (without the cc— prefix)
  fi
  if _drop_row "$name"; then
    _g "✓ removed: $name"; echo
  else
    _y "not in registry: $name"; echo
  fi
}

# Split a TSV registry line into ROW_NAME/UUID/CWD/EFFORT/RC, PRESERVING empty
# fields. `IFS=$'\t' read` collapses consecutive tabs (tab is a whitespace IFS),
# which drops an empty effort field and shifts rc into it — so don't use it.
_split_row() {
  local rest="$1"
  ROW_NAME="${rest%%$'\t'*}";   rest="${rest#*$'\t'}"
  ROW_UUID="${rest%%$'\t'*}";   rest="${rest#*$'\t'}"
  ROW_CWD="${rest%%$'\t'*}";    rest="${rest#*$'\t'}"
  ROW_EFFORT="${rest%%$'\t'*}"; rest="${rest#*$'\t'}"
  ROW_RC="$rest"
}

# ──────────────────────────────────────────────────────────────────
cmd_ls() {
  ensure_registry
  printf "  %-46s  %-5s  %-8s  %-7s  %s\n" "tmux session" "live" "effort" "rc" "cwd"
  printf "  %-46s  %-5s  %-8s  %-7s  %s\n" "$(printf '%.0s-' {1..46})" "-----" "--------" "-------" "----"
  local n_total=0 n_live=0
  while IFS= read -r _line || [[ -n "$_line" ]]; do
    [[ -z "$_line" || "${_line:0:1}" == "#" ]] && continue
    _split_row "$_line"
    local name="$ROW_NAME" uuid="$ROW_UUID" cwd="$ROW_CWD" effort="$ROW_EFFORT" rc="$ROW_RC"
    n_total=$((n_total+1))
    local live="✗"
    if tmux has-session -t "=$name" 2>/dev/null; then live="✓"; n_live=$((n_live+1)); fi
    local cwd_mark="$cwd"
    [[ -d "$cwd" ]] || cwd_mark="$cwd  (missing)"
    printf "  %-46s  %-5s  %-8s  %-7s  %s\n" "$name" "$live" "${effort:-—}" "$([[ "${rc:-1}" == 1 ]] && echo yes || echo no)" "$cwd_mark"
  done < "$TSV"
  echo
  echo "  $n_live/$n_total live   (registry: $TSV)"
}

# ── drive a freshly-resumed pane: answer the resume dialog, re-enable RC ──
_drive_restore() {
  local name="$1" rc="$2" title="${name#cc${EM}}"
  local deadline=$((SECONDS + 60)) pane did_rc=0 confirmed_rc=0
  while (( SECONDS < deadline )); do
    pane=$(tmux capture-pane -p -J -t "=$name" -S -200 2>/dev/null || true)
    # 1) "Resume session?" dialog → land on option 2 (full), never a summary.
    #    Drive by the cursor's ACTUAL position (the ❯ marker) each pass: press Down
    #    only while the cursor isn't yet on "full" (so it never overshoots to
    #    "Don't ask"), and re-send Enter while it is — a dropped Down or dropped
    #    Enter just retries on the next pass instead of leaving the dialog stuck.
    if grep -q 'Resume full session as-is' <<<"$pane"; then
      if grep -qE '❯.*Resume full session as-is' <<<"$pane"; then
        tmux send-keys -t "=$name" Enter; sleep 1.2
      else
        tmux send-keys -t "=$name" Down; sleep 0.5
      fi
      continue
    fi
    # 2) once the TUI is ready, re-issue /remote-control if this was an RC session
    if [[ "$rc" == "1" ]] && (( !did_rc )) && grep -q 'bypass permissions on' <<<"$pane"; then
      tmux send-keys -t "=$name" "/remote-control ${title}"; sleep 0.4
      tmux send-keys -t "=$name" Enter; sleep 1
      did_rc=1
      continue
    fi
    # 3) auto-confirm the one-time "Enable Remote Control" prompt
    if (( !confirmed_rc )) && grep -q 'Enable Remote Control' <<<"$pane"; then
      tmux send-keys -t "=$name" Enter; sleep 0.5
      confirmed_rc=1
      continue
    fi
    # done: RC active, or non-RC session that's ready
    if [[ "$rc" == "1" ]]; then
      grep -qE 'rc active|Remote Control active' <<<"$pane" && return 0
    else
      grep -q 'bypass permissions on' <<<"$pane" && return 0
    fi
    sleep 1
  done
  return 0   # best-effort; never block the restore loop
}

# ──────────────────────────────────────────────────────────────────
cmd_restore() {
  ensure_registry
  [[ -x "$CLAUDE" ]] || die "claude not executable at $CLAUDE (set \$CLAUDE)"
  command -v tmux >/dev/null || die "tmux not installed"

  if ! "$CLAUDE" auth status 2>/dev/null | grep -q '"loggedIn": true'; then
    _y "⚠ claude not logged in — sessions will start but API calls 401 until: $CLAUDE auth login"; echo
  fi

  local launched=0 skipped=0 waiting=0
  while IFS= read -r _line || [[ -n "$_line" ]]; do
    [[ -z "$_line" || "${_line:0:1}" == "#" ]] && continue
    _split_row "$_line"
    local name="$ROW_NAME" uuid="$ROW_UUID" cwd="$ROW_CWD" effort="$ROW_EFFORT" rc="$ROW_RC"
    rc="${rc:-1}"

    if tmux has-session -t "=$name" 2>/dev/null; then
      skipped=$((skipped+1)); continue
    fi
    # cwd not ready (e.g. a network mount still down) → leave for the next tick
    if [[ ! -d "$cwd" ]] || ! timeout 8 ls "$cwd" >/dev/null 2>&1; then
      _y "  … waiting on cwd: $name ($cwd)"; echo
      waiting=$((waiting+1)); continue
    fi

    local launch="$CLAUDE --dangerously-skip-permissions --resume $uuid"
    [[ -n "${effort:-}" ]] && launch+=" --effort $effort"
    if tmux new-session -d -s "$name" -c "$cwd" "$launch" 2>/dev/null; then
      _drive_restore "$name" "$rc"
      _g "  ✨ restored: $name"; echo
      launched=$((launched+1))
    else
      _r "  ✗ tmux launch failed: $name"; echo
      notify "⚠ claude-keep: session '$name' is down and tmux relaunch failed — needs a human"
    fi
  done < "$TSV"

  echo
  echo "restore: launched=$launched, already-live=$skipped, waiting-on-cwd=$waiting"
}

# ──────────────────────────────────────────────────────────────────
cmd_install_timer() {
  local interval=5
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --interval) interval="${2:-5}"; shift ;;
      *) die "install-timer: unknown arg '$1'" ;;
    esac
    shift
  done
  local self; self=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/claude-keep
  local ud="$HOME/.config/systemd/user"
  mkdir -p "$ud"

  cat > "$ud/claude-keep-restore.service" <<EOF
[Unit]
Description=claude-session-keeper — restore missing sessions
[Service]
Type=oneshot
Environment=CLAUDE_KEEP_HOME=$CLAUDE_KEEP_HOME
ExecStart=$self restore
EOF

  cat > "$ud/claude-keep-restore.timer" <<EOF
[Unit]
Description=claude-session-keeper — periodic self-heal
[Timer]
OnBootSec=2min
OnUnitActiveSec=${interval}min
Persistent=true
[Install]
WantedBy=timers.target
EOF

  systemctl --user daemon-reload
  systemctl --user enable --now claude-keep-restore.timer >/dev/null 2>&1
  # survive logout / run after reboot without an active login session
  loginctl enable-linger "$USER" >/dev/null 2>&1 || \
    _y "⚠ could not enable-linger; timer may not run before you log in after a reboot"

  _g "✓ timer installed: every ${interval} min (+2 min after boot)"; echo
  echo "    check:  systemctl --user list-timers claude-keep-restore.timer"
  echo "    logs:   journalctl --user -u claude-keep-restore.service"
}

cmd_uninstall_timer() {
  local ud="$HOME/.config/systemd/user"
  systemctl --user disable --now claude-keep-restore.timer >/dev/null 2>&1
  rm -f "$ud/claude-keep-restore.timer" "$ud/claude-keep-restore.service"
  systemctl --user daemon-reload
  _g "✓ timer removed"; echo
}

# ══════════════════════════════════════════════════════════════════════════════
# rc-restore — re-establish Remote Control on LIVE sessions whose RC channel
# dropped, and alert when a manual re-login is what's actually blocking it.
#
# Unlike `restore` (which relaunches DEAD sessions → a new claude process), this
# touches only sessions whose process is still running: it just re-issues
# /remote-control into the existing pane. That's cheap (a websocket, not a fork),
# so the metric gate here is a light backstop, not the main brake.
#
# Detection is deliberately guarded (RC state scraped from a TUI is fuzzy):
#   • BUSY sessions (mid-generation) are never touched;
#   • a 'dropped' read must repeat RC_FAIL_THRESHOLD times before we act
#     (hysteresis — a transient mis-read doesn't trigger a spurious re-issue);
#   • re-issuing on an already-active session only opens a dialog we dismiss, so
#     a false positive is harmless, not destructive.
# ══════════════════════════════════════════════════════════════════════════════
RC_STATE_DIR="${RC_STATE_DIR:-$HOME/.cache/claude-keep-rc}"
RC_FAIL_THRESHOLD="${RC_FAIL_THRESHOLD:-2}"   # consecutive 'dropped' reads before acting
RC_FIRST="${RC_FIRST:-dev-helper}"            # reconnect a session matching this substring FIRST
RC_GATE_MEM_MIN="${RC_GATE_MEM_MIN:-300}"     # MiB-available floor (stop if below)
RC_PAUSE="${RC_PAUSE:-5}"                     # seconds between reconnects
RC_MAX_PER_RUN="${RC_MAX_PER_RUN:-4}"         # reconnect at most N per run. Mass reconnect episodes
                                              # correlated with a load spike (observed ~13 on 4 cores),
                                              # so cap the batch and let the Persistent timer converge
                                              # over ticks. NB: the spike's true cause is unverified
                                              # (an earlier "npm auto-updater" guess was a bogus pgrep
                                              # match on the .npm-global path — there was no npm storm).

_nproc() { nproc 2>/dev/null || echo 4; }
_avail_mib() { free -m 2>/dev/null | awk '/Mem:/{print $7}'; }
_load1() { cut -d' ' -f1 /proc/loadavg 2>/dev/null || echo 0; }
GATE_WHY=""
_gate_ok() {
  # avail-mem is the REAL constraint for RC reconnects (a websocket, not a fork);
  # load spikes transiently from each session's npm auto-update, not from RC — so the
  # load ceiling is generous (2.5× cores) and mem is the tight gate. Both overridable.
  local mem load max
  mem=$(_avail_mib); load=$(_load1)
  max="${RC_GATE_LOAD_MAX:-$(awk -v c="$(_nproc)" 'BEGIN{print c*2.5}')}"
  if ! awk -v m="${mem:-0}" -v min="$RC_GATE_MEM_MIN" 'BEGIN{exit (m>=min)?0:1}'; then
    GATE_WHY="avail ${mem}MiB < ${RC_GATE_MEM_MIN}MiB"; return 1; fi
  if ! awk -v l="${load:-0}" -v mx="$max" 'BEGIN{exit (l<=mx)?0:1}'; then
    GATE_WHY="load ${load} > ${max}"; return 1; fi
  return 0
}

# per-session hysteresis counter (session names carry '/', sanitise for a filename)
_rc_failfile() { printf '%s/fail-%s' "$RC_STATE_DIR" "$(printf '%s' "$1" | tr '/ ' '__')"; }
_rc_bump_fail() { local n; n=$(( $(cat "$(_rc_failfile "$1")" 2>/dev/null || echo 0) + 1 )); echo "$n" > "$(_rc_failfile "$1")" 2>/dev/null || true; echo "$n"; }
_rc_reset_fail() { rm -f "$(_rc_failfile "$1")" 2>/dev/null || true; }

# Tier-1 machine-wide login state from the SHARED OAuth credential file.
# All sessions share ~/.claude/.credentials.json, so this is read once, not per-session.
# Returns: ok | login-needed
#
# IMPORTANT: `expiresAt` in the past is NORMAL, not "login needed". That field is the
# ACCESS token's expiry; as long as a refreshToken is present it refreshes transparently
# on next use (observed: a design token 97h "expired" yet still working). So the only
# hard, file-visible "run /login" signal is a MISSING oauth block or MISSING refreshToken
# (genuinely logged out / revoked). A refresh that fails despite a present refreshToken
# isn't visible here — that surfaces as a /login prompt in the pane (a future Tier-3 add).
_login_state() {
  local f="$HOME/.claude/.credentials.json"
  [[ -r "$f" ]] || { echo ok; return; }   # can't read → don't false-alarm
  python3 - "$f" <<'PY' 2>/dev/null || echo ok
import json,sys
try: d=json.load(open(sys.argv[1]))
except Exception: print("ok"); sys.exit()
o=d.get("claudeAiOauth")
if not o or not o.get("refreshToken"):   # no way to refresh → real re-login needed
    print("login-needed"); sys.exit()
print("ok")                              # refreshToken present → expired access auto-refreshes
PY
}

# Resolve a session name to its pane id via EXACT-match. capture-pane's `-t =name`
# exact form silently returns empty for these em-dash/slash session names, and the
# `=`-less form prefix-matches (jeevy vs jeevy-2/-3 collide) → wrong pane. Matching
# the full name in awk and capturing by pane id (%N) is exact and collision-proof.
_pane_of() { tmux list-panes -a -F $'#{session_name}\t#{pane_id}' 2>/dev/null | awk -F'\t' -v s="$1" '$1==s{print $2; exit}'; }

# RC state of a LIVE session, from its pane. Returns: active | dropped | busy
# Signals learned by hand: fresh activation prints "remote-control is active";
# a re-issue on a connected session opens a mgmt panel ("available in the Claude
# mobile app" / "Disconnect this session"); the status bar shows "/rc active".
_rc_state() {
  local pid; pid=$(_pane_of "$1")
  [[ -z "$pid" ]] && { echo dropped; return; }
  local cap; cap=$(tmux capture-pane -p -J -t "$pid" -S -60 2>/dev/null || true)
  [[ -z "$cap" ]] && { echo dropped; return; }
  grep -q 'esc to interrupt' <<<"$cap" && { echo busy; return; }
  grep -qiE 'remote-control is active|Remote Control active|available in the Claude mobile app|/rc active' \
    <<<"$cap" && { echo active; return; }
  echo dropped
}

# Re-issue /remote-control into a live pane and drive it to active. Handles the
# transient that ate the command (re-issues every ~8s), the mgmt dialog (dismiss
# with Enter), and the one-time "Enable Remote Control" confirm. 30s budget.
_reconnect_rc() {
  local name="$1" title="${name#cc${EM}}" pid pane end=$((SECONDS+30)) last=0
  pid=$(_pane_of "$name"); [[ -z "$pid" ]] && return 1
  while (( SECONDS < end )); do
    pane=$(tmux capture-pane -p -J -t "$pid" -S -60 2>/dev/null || true)
    if grep -qiE 'remote-control is active|Remote Control active|available in the Claude mobile app|/rc active' <<<"$pane"; then
      # a mgmt dialog may be sitting open on top of the active state — dismiss it
      grep -qiE 'Disconnect this session|Enter to select|Esc to continue' <<<"$pane" && { tmux send-keys -t "$pid" Enter; sleep 1; }
      return 0
    fi
    # "connecting…" means the command took and RC is establishing — it settles to
    # active on its own. Treat as success (don't wait for active, and crucially don't
    # re-issue, which would interrupt the in-flight connect).
    grep -qiE '/rc connecting|remote.control.*connecting' <<<"$pane" && return 0
    if grep -q 'Enable Remote Control' <<<"$pane"; then tmux send-keys -t "$pid" Enter; sleep 1; continue; fi
    if (( SECONDS - last >= 8 )); then
      tmux send-keys -t "$pid" -l "/remote-control ${title}"; sleep 0.4; tmux send-keys -t "$pid" Enter
      last=$SECONDS
    fi
    sleep 2
  done
  return 1
}

cmd_rc_restore() {
  ensure_registry
  command -v tmux >/dev/null || die "tmux not installed"
  mkdir -p "$RC_STATE_DIR" 2>/dev/null || true
  local now_mode=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --now) now_mode=1 ;;                         # act immediately (skip hysteresis) — for on-demand
      *) die "rc-restore: unknown arg '$1'" ;;
    esac; shift
  done
  (( now_mode )) && RC_FAIL_THRESHOLD=1

  # ── Tier-1: login (machine-wide) ──
  local st; st=$(_login_state)
  if [[ "$st" == login-needed ]]; then
    if [[ ! -e "$RC_STATE_DIR/login-alerted" ]]; then
      notify "⚠ claude-keep: Claude OAuth token expired and refresh isn't happening — log in on the server ('claude auth login' / /login). Remote Control stays down until then."
      : > "$RC_STATE_DIR/login-alerted"
    fi
    _y "⚠ login needed (token expired, refresh not happening) — alerted; skipping RC work"; echo
    return 0
  fi
  rm -f "$RC_STATE_DIR/login-alerted" 2>/dev/null || true

  # ── collect LIVE rc=1 sessions, RC_FIRST first ──
  local -a order=() rest=()
  while IFS= read -r _line || [[ -n "$_line" ]]; do
    [[ -z "$_line" || "${_line:0:1}" == "#" ]] && continue
    _split_row "$_line"
    [[ "${ROW_RC:-1}" == 1 ]] || continue
    tmux has-session -t "=$ROW_NAME" 2>/dev/null || continue    # only LIVE sessions (dead → `restore`)
    if [[ "$ROW_NAME" == *"$RC_FIRST"* ]]; then order+=("$ROW_NAME"); else rest+=("$ROW_NAME"); fi
  done < "$TSV"
  (( ${#rest[@]} )) && order+=("${rest[@]}")
  (( ${#order[@]} )) || { echo "rc-restore: no live rc sessions in the registry"; return 0; }

  local reconnected=0 active=0 busy=0 suspect=0 gated=0 failed=0 name state n
  for name in "${order[@]}"; do
    state=$(_rc_state "$name")
    if [[ "$state" == active ]]; then active=$((active+1)); _rc_reset_fail "$name"; continue; fi
    if [[ "$state" == busy   ]]; then busy=$((busy+1)); continue; fi    # never disturb a working session
    # dropped → hysteresis
    n=$(_rc_bump_fail "$name")
    if (( n < RC_FAIL_THRESHOLD )); then suspect=$((suspect+1)); _y "  suspect ($n/$RC_FAIL_THRESHOLD): ${name#cc${EM}}"; echo; continue; fi
    if ! _gate_ok; then
      gated=1
      # dedup: one alert per loaded episode, not one per tick (cleared on a clean run below)
      if [[ ! -e "$RC_STATE_DIR/gate-alerted" ]]; then
        notify "⚠ claude-keep rc: machine loaded ($GATE_WHY) — pausing RC restore; will resume when load drops. Some sessions still without RC."
        : > "$RC_STATE_DIR/gate-alerted"
      fi
      _r "  ✗ gate: $GATE_WHY — stopping"; echo; break
    fi
    _b "  → reconnecting: ${name#cc${EM}}"; echo
    if _reconnect_rc "$name"; then _rc_reset_fail "$name"; reconnected=$((reconnected+1)); _g "    ✓ RC active"; echo
    else failed=$((failed+1)); _r "    ✗ RC not confirmed"; echo; fi
    # cap per run: leave the rest for the next tick so the npm-update load stays spread out
    (( reconnected >= RC_MAX_PER_RUN )) && { _y "  reached max per run ($RC_MAX_PER_RUN) — rest next tick"; echo; break; }
    sleep "$RC_PAUSE"
  done
  # a run that finished without tripping the gate clears the dedup flag (episode over)
  (( gated == 0 )) && rm -f "$RC_STATE_DIR/gate-alerted" 2>/dev/null || true

  echo
  echo "rc-restore: reconnected=$reconnected already-active=$active busy=$busy suspect=$suspect failed=$failed$([[ $gated == 1 ]] && echo ' GATED')"
}

cmd_install_rc_timer() {
  local interval=5
  while [[ $# -gt 0 ]]; do
    case "$1" in --interval) interval="${2:-5}"; shift ;; *) die "install-rc-timer: unknown arg '$1'" ;; esac; shift
  done
  local self; self=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/claude-keep
  local ud="$HOME/.config/systemd/user"; mkdir -p "$ud"
  cat > "$ud/claude-keep-rc.service" <<EOF
[Unit]
Description=claude-session-keeper — re-establish Remote Control on live sessions
[Service]
Type=oneshot
Environment=CLAUDE_KEEP_HOME=$CLAUDE_KEEP_HOME
ExecStart=$self rc-restore
EOF
  cat > "$ud/claude-keep-rc.timer" <<EOF
[Unit]
Description=claude-session-keeper — periodic Remote Control monitor
[Timer]
OnBootSec=3min
OnUnitActiveSec=${interval}min
Persistent=true
[Install]
WantedBy=timers.target
EOF
  systemctl --user daemon-reload
  systemctl --user enable --now claude-keep-rc.timer >/dev/null 2>&1
  loginctl enable-linger "$USER" >/dev/null 2>&1 || true
  _g "✓ RC monitor timer installed: every ${interval} min (+3 min after boot)"; echo
  echo "    check:  systemctl --user list-timers claude-keep-rc.timer"
  echo "    logs:   journalctl --user -u claude-keep-rc.service"
}

cmd_uninstall_rc_timer() {
  local ud="$HOME/.config/systemd/user"
  systemctl --user disable --now claude-keep-rc.timer >/dev/null 2>&1
  rm -f "$ud/claude-keep-rc.timer" "$ud/claude-keep-rc.service"
  systemctl --user daemon-reload
  _g "✓ RC monitor timer removed"; echo
}

usage() {
  sed -n '2,40p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//'
}

# ──────────────────────────────────────────────────────────────────
main() {
  local cmd="${1:-}"; shift || true
  case "$cmd" in
    add)              cmd_add "$@" ;;
    rm|remove)        cmd_rm "$@" ;;
    ls|list|status)   cmd_ls "$@" ;;
    restore)          cmd_restore "$@" ;;
    rc-restore|rc)    cmd_rc_restore "$@" ;;
    install-timer)    cmd_install_timer "$@" ;;
    uninstall-timer)  cmd_uninstall_timer "$@" ;;
    install-rc-timer)   cmd_install_rc_timer "$@" ;;
    uninstall-rc-timer) cmd_uninstall_rc_timer "$@" ;;
    ""|help|-h|--help) usage ;;
    *) die "unknown command '$cmd' (try: claude-keep help)" ;;
  esac
}
main "$@"
